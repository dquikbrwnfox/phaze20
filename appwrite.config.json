{
  "projectId": "6a228c77000c28cb23ec",
  "endpoint": "https://nyc.cloud.appwrite.io/v1",
  "functions": [
    {
      "$id": "cleanup-reactions",
      "name": "cleanup-reactions",
      "enabled": true,
      "live": true,
      "logging": true,
      "runtime": "node-22",
      "schedule": "0 * * * *",
      "timeout": 15,
      "entrypoint": "src/main.js",
      "commands": "npm install",
      "version": "v3",
      "path": "functions/cleanup-reactions",
      "vars": [
        {
          "key": "APPWRITE_ENDPOINT",
          "value": "https://nyc.cloud.appwrite.io/v1"
        },
        {
          "key": "APPWRITE_PROJECT_ID",
          "value": "6a228c77000c28cb23ec"
        },
        {
          "key": "APPWRITE_DB_ID",
          "value": "phaze20"
        },
        {
          "key": "REACTION_MAX_AGE_MINUTES",
          "value": "60"
        }
      ]
    }
  ],
  "sites": [
    {
      "$id": "phaze20-app",
      "name": "Phaze20",
      "logging": true,
      "framework": "react",
      "timeout": 30,
      "installCommand": "npm install -g pnpm@11.5.2 && pnpm install",
      "buildCommand": "pnpm build",
      "outputDirectory": "./dist",
      "specification": "s-1vcpu-512mb",
      "buildRuntime": "node-22",
      "adapter": "static",
      "fallbackFile": "index.html",
      "path": ".",
      "vars": [
        { "key": "VITE_APPWRITE_ENDPOINT", "value": "https://nyc.cloud.appwrite.io/v1" },
        { "key": "VITE_APPWRITE_PROJECT_ID", "value": "6a228c77000c28cb23ec" },
        { "key": "VITE_APPWRITE_DB_ID", "value": "phaze20" },
        { "key": "VITE_APP_NAME", "value": "Phaze20" }
      ]
    }
  ],
  "tablesDB": [
